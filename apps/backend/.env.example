# ─────────────────────────────────────────────────────────────────
# RakshaAI Backend — Environment Variables
# Copy the values you need into ../../.env and fill in real values
# NEVER commit the root .env — it is in .gitignore
# ─────────────────────────────────────────────────────────────────

# ─── Server ───────────────────────────────────────────────────────
NODE_ENV=development
HOST=127.0.0.1
PORT=5000

# ─── Database (PostgreSQL + PostGIS) ─────────────────────────────
DATABASE_URL=postgresql://rakshaai_user:your_password@localhost:5432/rakshaai_db?schema=public

# ─── JWT ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_byte_hex_secret
JWT_REFRESH_SECRET=replace_with_64_byte_hex_secret_different
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── SMTP / Email (Nodemailer) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=RakshaAI <your_email@gmail.com>

# ─── Twilio SMS (fallback alerts) ─────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Gemini AI ────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── Firebase Cloud Messaging ────────────────────────────────────
FIREBASE_SERVER_KEY=your_firebase_server_key
FIREBASE_PROJECT_ID=your_firebase_project_id

# ─── CORS ─────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# ─── Rate Limiting ────────────────────────────────────────────────
# Window in ms (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# RakshaAI Web App — Environment Variables
# Copy local values into ../../.env for development, or create .env.production here before a production web build.

# Backend API base URL
NEXT_PUBLIC_API_URL=http://127.0.0.1:5000/api

# WebSocket server URL
NEXT_PUBLIC_WS_URL=http://127.0.0.1:5000
NEXT_PUBLIC_SOCKET_URL=http://127.0.0.1:5000

# App metadata
NEXT_PUBLIC_APP_NAME=RakshaAI
NEXT_PUBLIC_APP_URL=http://localhost:3000

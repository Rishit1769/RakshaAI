{
  "name": "@rakshaai/web",
  "version": "1.0.0",
  "private": true,
  "description": "RakshaAI Web — Next.js App Router frontend",
  "scripts": {
    "dev": "NPM_CONFIG_LOGLEVEL=silent next dev -H 0.0.0.0 -p 3001",
    "build": "NPM_CONFIG_LOGLEVEL=silent next build",
    "start": "next start -H 127.0.0.1 -p 3001",
    "lint": "NPM_CONFIG_LOGLEVEL=silent next lint",
    "clean": "rimraf .next out",
    "postinstall": "mkdir -p public/leaflet && (cp ../../node_modules/leaflet/dist/images/* public/leaflet/ 2>/dev/null || cp node_modules/leaflet/dist/images/* public/leaflet/)"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.32.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "leaflet": "^1.9.4",
    "next": "14.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.7.5",
    "tailwind-merge": "^2.3.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.3",
    "postcss": "^8.4.38",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5"
  }
}

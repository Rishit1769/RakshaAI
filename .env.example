NODE_ENV=development
PORT=5000

DATABASE_URL="postgresql://postgres:159753@localhost:5432/app_db"

JWT_ACCESS_SECRET=replace_with_64_byte_hex_secret
JWT_REFRESH_SECRET=replace_with_64_byte_hex_secret_different
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=RakshaAI <your_email@gmail.com>

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_NAME=
MINIO_USE_SSL=false
MINIO_APK_OBJECT_KEY=app/release.apk

GEMINI_API_KEY=your_gemini_api_key
FIREBASE_SERVER_KEY=
FIREBASE_PROJECT_ID=

CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=http://localhost
